# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL — create a db and user first:
#   sudo -u postgres psql
#   CREATE USER yourname WITH PASSWORD 'yourpassword';
#   CREATE DATABASE safety_dashboard OWNER yourname;
DATABASE_URL=postgresql://yourname:yourpassword@localhost:5432/safety_dashboard

# JWT Secret — any long random string works
JWT_SECRET=change-this-to-any-long-random-string

# Frontend URL (for CORS) — default Vite port
FRONTEND_URL=http://localhost:5173

# Local file storage — change BASE_URL to your server IP/domain on production
UPLOAD_DIR=/app/uploads
BASE_URL=http://localhost:8000
